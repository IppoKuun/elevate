generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    schemas  = ["app", "auth"]
}

model StaffProfile {
  id             String            @id @default(uuid())
  name           String
  email          String            @unique
  createdAt      DateTime          @default(now())
  role           StaffRoles        @default(VIEWER)
  userId         String            @unique
  InvitationSent StaffInvitation[] @relation("InvitedBy")

  @@index([role])
  @@index([name])
  @@map("staff_profile")
  @@schema("app")
}

model StaffInvitation {
  id               String       @id @default(uuid())
  email            String       @unique
  role             StaffRoles   @default(VIEWER)
  tokenHash        String       @unique
  createdAt        DateTime
  acceptedAt       DateTime?
  revokeAt         DateTime?
  expiredAt        DateTime
  acceptedByUserId String?      @unique
  invitedById      String
  InvitedBy        StaffProfile @relation("InvitedBy", fields: [invitedById], references: [id])

  @@schema("app")
}

model Cours {
  id                  String         @id @default(uuid())
  title               String
  content             String         @default("")
  slug                String         @unique
  thumbnailUrl        String?
  thumbnailPublicId   String?
  description         String?
  priceCents          Int?
  createdByAuthUserId String?
  category            CoursCategory?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  isPaid              Boolean?
  stripeProductId     String?        @unique
  stripePriceId       String?        @unique
  purchases           CoursePurchase[]

  @@index([title])
  @@index([priceCents])
  @@map("cours")
  @@schema("app")
}

model CoursePurchase {
  id                      String         @id @default(uuid())
  authUserId              String
  courseId                String
  status                  PurchaseStatus @default(PENDING)
  amountCents             Int
  currency                String         @default("eur")
  stripeCheckoutSessionId String         @unique
  stripePaymentIntentId   String?        @unique
  stripeCustomerId        String?
  paidAt                  DateTime?
  refundedAt              DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  course                  Cours          @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@unique([authUserId, courseId])
  @@index([authUserId])
  @@index([courseId])
  @@index([status])
  @@index([createdAt])
  @@schema("app")
}

model WebhookEvent {
  id           String        @id @default(cuid())
  eventId      String        @unique
  eventType    String
  status       WebhookStatus @default(RECEIVED)
  payload      Json
  attemptCount Int           @default(0)
  lastError    String?
  receivedAt   DateTime      @default(now())
  processedAt  DateTime?

  @@index([provider])
  @@index([status])
  @@index([eventType])
  @@index([receivedAt])
  @@schema("app")
}


model AuditLog {
  id              String   @id @default(uuid())
  action          String
  actorAuthUserId String?
  entityType      String?
  entityId        String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([action])
  @@index([actorAuthUserId])
  @@index([createdAt])
  @@map("audit_log")
  @@schema("app")
}


enum CoursCategory {
  DEVELOPMENT
  DESIGN
  BUSINESS
  MARKETING
  DATA_SCIENCE
  IT_SOFTWARE
  PERSONAL_DEVELOPMENT
  PHOTOGRAPHY
  MUSIC
  LANGUAGE
  HEALTH_FITNESS
  FINANCE
  LIFESTYLE
  TEACHING

  @@schema("app")
}

enum StaffRoles {
  OWNER
  ADMIN
  VIEWER
  TEST

  @@schema("app")
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELED

  @@schema("app")
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED

  @@schema("app")
}
