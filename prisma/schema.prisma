generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    schemas  = ["app", "auth"]
}

model StaffProfile {
  id             String            @id @default(uuid())
  name           String
  email          String            @unique
  createdAt      DateTime          @default(now())
  role           StaffRoles        @default(VIEWER)
  userId         String            @unique
  InvitationSent StaffInvitation[] @relation("InvitedBy")

  @@index([role])
  @@index([name])
  @@map("staff_profile")
  @@schema("app")
}

model StaffInvitation {
  id               String       @id @default(uuid())
  email            String       @unique
  role             StaffRoles   @default(VIEWER)
  tokenHash        String       @unique
  createdAt        DateTime
  acceptedAt       DateTime?
  revokeAt         DateTime?
  expiredAt        DateTime
  acceptedByUserId String?      @unique
  invitedById      String
  InvitedBy        StaffProfile @relation("InvitedBy", fields: [invitedById], references: [id])

  @@schema("app")
}

model Cours {
  id                  String         @id @default(uuid())
  title               String
  slug                String         @unique
  description         String?
  price               Decimal
  createdByAuthUserId String?
  category            CoursCategory?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([title])
  @@index([price])
  @@map("cours")
  @@schema("app")
}

model AuditLog {
  id              String   @id @default(uuid())
  action          String
  actorAuthUserId String?
  entityType      String?
  entityId        String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([action])
  @@index([actorAuthUserId])
  @@index([createdAt])
  @@map("audit_log")
  @@schema("app")
}


enum CoursCategory {
  DEVELOPMENT
  DESIGN
  BUSINESS
  MARKETING
  DATA_SCIENCE
  IT_SOFTWARE
  PERSONAL_DEVELOPMENT
  PHOTOGRAPHY
  MUSIC
  LANGUAGE
  HEALTH_FITNESS
  FINANCE
  LIFESTYLE
  TEACHING

  @@schema("app")
}

enum StaffRoles {
  OWNER
  ADMIN
  VIEWER
  TEST

  @@schema("app")
}
